{
  "name": "requiem-server",
  "version": "1.0.0",
  "description": "Node.js backend scaffold for Shadows of Eltania",
  "license": "ISC",
  "author": "temp0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run db:content:inflate",
    "dev": "tsx watch src/index.ts",
    "libra:dev": "node scripts/run-libra-dev.mjs",
    "libra:api:dev": "npm run db:content:inflate && tsx watch src/libra/dev.ts",
    "libra:ui:dev": "npm --prefix libra-ui run dev",
    "libra:ui:build": "npm --prefix libra-ui run build",
    "libra:ui:lint": "npm --prefix libra-ui run lint",
    "cert:dev:generate": "bash scripts/generate-local-cert.sh",
    "cert:dev:trust:mac": "bash scripts/trust-local-cert-macos.sh",
    "build": "npm run wasm:build && tsc -p tsconfig.json && mkdir -p dist/zone/wasm && cp src/zone/wasm/*.wasm dist/zone/wasm/",
    "prestart": "npm run db:content:inflate",
    "start": "node dist/index.js",
    "lint": "oxlint --ignore-pattern 'src/protocol/generated/**' src",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json",
    "test": "tsx --test src/**/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "db:hydrate:mysql": "tsx scripts/hydrate-sqlite-from-mysql.ts",
    "db:hydrate:verify": "tsx scripts/verify-sqlite-hydration.ts",
    "db:schema:apply": "tsx scripts/apply-canonical-schema.ts",
    "db:promote:imported": "npm run db:schema:apply && tsx scripts/promote-imported-data.ts",
    "db:promote": "npm run db:promote:mysql && npm run db:content:export",
    "db:promote:mysql": "tsx scripts/promote-mysql-to-canonical.ts",
    "db:content:export": "tsx scripts/export-content-sqlite.ts",
    "db:content:inflate": "tsx scripts/inflate-content-sqlite.ts",
    "db:content:inflate:force": "tsx scripts/inflate-content-sqlite.ts --force",
    "db:offline:seed": "npm run db:content:export",
    "wt:smoke": "tsx scripts/webtransport-smoke.ts",
    "wt:smoke:login-char": "tsx scripts/webtransport-smoke-login-char.ts",
    "wt:dump:char-list": "tsx scripts/webtransport-dump-char-list.ts",
    "wt:smoke:browser-connect": "tsx scripts/webtransport-browser-connect-smoke.ts",
    "wt:validate:cert-hash": "tsx scripts/webtransport-validate-live-cert-hash.ts",
    "wt:profile": "tsx scripts/webtransport-profile.ts",
    "net:generate": "tsx scripts/generate-net-structs.ts",
    "net:check": "tsx scripts/check-net-structs-sync.ts",
    "offline:gear:generate": "tsx scripts/generate-offline-gear-catalog.ts",
    "wasm:build": "shado asc build --config ./shado.config.mjs"
  },
  "dependencies": {
    "@fails-components/webtransport": "^1.6.6",
    "@fails-components/webtransport-transport-http3-quiche": "^1.6.6",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "better-sqlite3": "^12.11.1",
    "drizzle-orm": "^0.45.2",
    "mysql2": "^3.22.6",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "assemblyscript": "^0.28.8",
    "binaryen": "^124.0.0",
    "oxlint": "^1.74.0",
    "shader-object": "file:../shader-object",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
