NODE_ENV=development
LOG_LEVEL=info

# WebTransport gateway
WT_HOST=::
WT_PORT=443
WT_PATH=/game
WT_CERT_MODE=ephemeral
WT_SECRET=shadows-of-eltania-dev-secret
WT_CERT_PATH=./certs/wt-dev-localhost-cert.pem
WT_KEY_PATH=./certs/wt-dev-localhost-key.pem

# Canonical DB URLs select the MySQL, PostgreSQL, or SQLite adapter.
# For an entirely local Node mock use sqlite::memory: or sqlite:/absolute/path.db.
# The current development flow automatically authenticates each connection as the guest identity.
CONTENT_DATABASE_URL=sqlite:./data/content-db.sqlite
RUNTIME_DATABASE_URL=sqlite:./data/runtime-db.sqlite
# PostgreSQL example: postgres://requiem:password@127.0.0.1:5432/requiem_content
# MySQL example: mysql://requiem:password@127.0.0.1:3307/requiem_content

# Per-zone JSON quests; watched and hot-reloaded in development.
QUEST_DIR=./quests

# Libra backend API
LIBRA_ENABLED=true
LIBRA_API_KEY=
LIBRA_READONLY_RUNTIME=true
LIBRA_MAX_PAGE_SIZE=500
LIBRA_WRITE_ALLOWLIST=*
LIBRA_VALIDATION_MAX_ISSUES=250
