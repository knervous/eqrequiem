{
  "kind": "shado.model.manifest",
  "version": 1,
  "models": {
    "barbarian": {
      "name": "barbarian",
      "import": {
        "kind": "asset-container",
        "url": "https://eqrequiem.blob.core.windows.net/dev/barbarian_1.glb"
      },
      "runtime": {
        "merge": true,
        "replaceMaterial": true,
        "disposeOriginalMaterial": false
      },
      "includeAnimation": true,
      "vat": {
        "variants": [
          "float16",
          "float32"
        ],
        "options": {
          "useHalfDQ": true
        }
      },
      "artifacts": {
        "model": "models/barbarian.model.json.gz",
        "vat16": "models/barbarian.vat16.json.gz",
        "vat32": "models/barbarian.vat32.json.gz"
      }
    },
    "arr": {
      "name": "arr",
      "import": {
        "kind": "scene-loader",
        "rootUrl": "https://raw.githubusercontent.com/RaggarDK/Baby/baby/",
        "fileName": "arr.babylon"
      },
      "runtime": {
        "merge": false,
        "replaceMaterial": true,
        "disposeOriginalMaterial": false
      },
      "includeAnimation": true,
      "vat": {
        "variants": [
          "float16",
          "float32"
        ],
        "options": {
          "useHalfDQ": true,
          "defaultFPS": 30,
          "manualAnimationRanges": [
            {
              "from": 0,
              "to": 33,
              "name": "Animation_0"
            },
            {
              "from": 33,
              "to": 61,
              "name": "Animation_1"
            },
            {
              "from": 63,
              "to": 91,
              "name": "Animation_2"
            },
            {
              "from": 93,
              "to": 130,
              "name": "Animation_3"
            }
          ]
        }
      },
      "artifacts": {
        "model": "models/arr.model.json.gz",
        "vat16": "models/arr.vat16.json.gz",
        "vat32": "models/arr.vat32.json.gz"
      }
    }
  }
}
