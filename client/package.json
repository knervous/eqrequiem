{
  "name": "requiem-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "net:generate": "npm --prefix ../serverjs run net:generate",
    "net:check": "node scripts/check-net-structs-sync.mjs",
    "prebuild": "npm run net:check",
    "sage:dev": "cross-env VITE_USE_SAGE=true VITE_LOCAL_DEV=true vite",
    "v": "vercel dev",
    "atlas": "node scripts/create-atlas.js ~/documents/everquest_rof2/eqrequiem/textures",
    "vat": "node scripts/vat.js ~/documents/everquest_rof2/eqrequiem",
    "bjs:models": "node scripts/bjs-export.js ~/documents/everquest_rof2/eqrequiem/models",
    "model:install-human": "node scripts/install-human-model.js",
    "model:install-human-female": "node scripts/install-human-model.js ../assets/src/models/human_female/eqref/human_female_locomotion_v10_pbr.glb huf",
    "model:install-humans": "npm run model:install-human && npm run model:install-human-female",
    "model:render-reference": "node scripts/render-glb-reference.mjs",
    "model:audit-rig": "node scripts/audit-humanoid-rig.mjs",
    "model:transplant-eq-rig": "node scripts/transplant-eq-rig.mjs",
    "bjs:items": "node scripts/bjs-export-full.js ~/documents/everquest_rof2/eqrequiem/items",
    "bjs:objects": "node scripts/bjs-export-full.js ~/documents/everquest_rof2/eqrequiem/objects",
    "bjs:zones": "node scripts/bjs-export-full.js ~/documents/everquest_rof2/eqrequiem/zones",
    "bjs:sky": "node scripts/bjs-export-full.js ~/documents/everquest_rof2/eqrequiem/sky",
    "bjs:all": "npm-run-all bjs:items bjs:objects bjs:zones bjs:sky",
    "upload": "node scripts/upload.js ~/documents/everquest_rof2",
    "upload:db": "node scripts/upload-db.js",
    "start": "cross-env VITE_LOCAL_DEV=true VITE_USE_SAGE=false vite",
    "start:prod": "cross-env VITE_LOCAL_DEV=false VITE_USE_SAGE=false vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint src --tsconfig tsconfig.json --react-plugin --import-plugin --deny-warnings --report-unused-disable-directives",
    "preview": "vite preview"
  },
  "dependencies": {
    "@babylonjs/core": "^9.5.0",
    "@babylonjs/havok": "^1.3.10",
    "@babylonjs/inspector": "^9.5.0",
    "@babylonjs/loaders": "^9.5.0",
    "@babylonjs/materials": "^9.5.0",
    "@babylonjs/serializers": "^9.5.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.2",
    "@mui/x-tree-view": "^7.26.0",
    "@protobuf-ts/runtime": "^2.9.6",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "allotment": "^1.20.4",
    "comlink": "^4.4.2",
    "drizzle-orm": "^0.45.2",
    "fantasy-name-generator": "^2.0.0",
    "gl-matrix": "^3.4.3",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "maxrects-packer": "^2.7.3",
    "mitt": "^3.0.1",
    "pako": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.2.0",
    "react-social-login-buttons": "^4.1.1",
    "sage-core": "^0.0.38",
    "shader-object": "file:../shader-object",
    "slate": "^0.117.2",
    "slate-history": "^0.113.1",
    "slate-react": "^0.117.4",
    "sparse-octree": "^7.1.8",
    "tga-js": "^1.1.1",
    "use-context-selector": "^2.0.0",
    "use-debounce": "^10.0.4"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@aaronhayes/hasura-cli": "^2.42.0",
    "@azure/identity": "^4.9.0",
    "@azure/storage-blob": "^12.27.0",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@itk-viewer/blosc-zarr": "^0.2.3",
    "@protobuf-ts/plugin": "^2.9.5",
    "@swc/react-compiler": "^1.12.7",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vercel/node": "^5.1.14",
    "@vingle/bmp-js": "^0.2.5",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "archiver": "^7.0.1",
    "cross-env": "^7.0.3",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "http-server": "^14.1.1",
    "jimp": "^1.6.0",
    "ktx-parse": "^1.0.0",
    "node-fetch": "^3.3.2",
    "node-lame": "^1.3.2",
    "npm-run-all": "^4.1.5",
    "oxlint": "^1.74.0",
    "p-limit": "^6.2.0",
    "rollup": "^4.37.0",
    "serve-static": "^1.16.2",
    "sharp": "^0.34.1",
    "sharp-bmp": "^0.1.5",
    "typescript": "^7.0.2",
    "vercel": "^41.4.1",
    "vite": "^8.1.4"
  }
}
