VITE_LOCAL_DEV=true

# WebTransport endpoint used by the game client.
VITE_WT_HOST=localhost
VITE_WT_PORT=443
VITE_WT_PATH=/game
VITE_WT_USE_CERT_HASH=true

# Optional override for where /api/hash should fetch the cert hash.
# Defaults to VITE_WT_HOST / VITE_WT_PORT if omitted.
VITE_WT_HASH_HOST=localhost
VITE_WT_HASH_PORT=443

# Optional override for non-WebTransport HTTP API calls (playercount, etc.).
VITE_API_BASE_URL=/api

# Optional playercount endpoint for server-select status.
# Leave unset in local dev to default to { count: 0 }.
# VITE_PLAYERCOUNT_URL=https://your-host/playercount

# Hash provider used by /api/hash in local dev.
VITE_HASH_PROVIDER_URL=http://localhost:8082/hash
# Run the backend in a module Worker with SQLite-Wasm and OPFS instead of WebTransport.
# This can also be enabled per URL with ?backend=local. Use ?offline=true to
# immediately enter Offline Mode through the local backend.
VITE_LOCAL_BACKEND=false
